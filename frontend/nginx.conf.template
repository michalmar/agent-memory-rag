# Rendered at container start by the nginx image's envsubst entrypoint.
# ${BACKEND_URL}, ${AUTH_MODE}, ${ENTRA_*}, ${BUILD_ID} come from Container App env.
# nginx runtime vars ($host, $uri, ...) are NOT in the environment, so envsubst leaves them intact.

server {
    listen 8080;
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    # Runtime app config consumed by the SPA (window.__APP_CONFIG__).
    location = /config.js {
        default_type application/javascript;
        add_header Cache-Control "no-store";
        return 200 'window.__APP_CONFIG__ = { apiBaseUrl: "/api", authMode: "${AUTH_MODE}", entraTenantId: "${ENTRA_TENANT_ID}", entraClientId: "${ENTRA_CLIENT_ID}", entraApiScope: "${ENTRA_API_SCOPE}", buildId: "${BUILD_ID}" };';
    }

    # Reverse-proxy API calls to the backend (internal ACA FQDN). Trailing slash
    # strips the /api prefix so /api/chat -> ${BACKEND_URL}/chat.
    location /api/ {
        proxy_pass ${BACKEND_URL}/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Server-Sent Events (chat stream): disable buffering, keep long-lived.
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
        proxy_set_header Connection "";
        chunked_transfer_encoding off;
    }

    # SPA fallback.
    location / {
        try_files $uri $uri/ /index.html;
    }
}
