# ---- Vertical slice (P0-P2) runs fully OFFLINE with these unset ----
# When AZURE_OPENAI_ENDPOINT is empty, the backend uses the MOCK LLM runner.

# Auth: mock header auth for local dev
AUTH_MODE=mock

# LLM runner: "mock" (default when no Azure endpoint) or "real"
LLM_MODE=mock

# ---- Real Azure path (later phases; leave blank for the offline slice) ----
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large

# Session memory: in-memory only for this build (no Redis)
# REDIS_HOST intentionally left unset.

# CORS: comma-separated allowed origins for the frontend dev server
CORS_ALLOW_ORIGINS=http://localhost:5175,http://127.0.0.1:5175
