# ---- Vertical slice (P0-P2) runs fully OFFLINE with these unset ----
# When AZURE_OPENAI_ENDPOINT is empty, the backend uses the MOCK LLM runner.

# Auth: mock header auth for local dev
AUTH_MODE=mock
APP_ENV=local
# Entra ID (production; set AUTH_MODE=entra). Audience = API app (client) id or api://<id>.
# ENTRA_TENANT_ID=
# ENTRA_AUDIENCE=
# ENTRA_ISSUER=            # optional; defaults to https://login.microsoftonline.com/<tenant>/v2.0
# ENTRA_JWKS_URI=          # optional; defaults to the tenant v2.0 discovery keys
# ENTRA_REQUIRED_SCOPES=   # optional; space/comma-delimited (e.g. access_as_user)
# ENTRA_REQUIRED_ROLES=    # optional; space/comma-delimited app roles
# AGENT_GATEWAY_AUDIENCE=api://<backend-client-id>
# AGENT_GATEWAY_REQUIRED_ROLE=AgentTools.Invoke
# HOSTED_AGENT_PRINCIPAL_IDS=<hosted-agent-principal-id>
# SUPPORT_HOSTED_AGENT_PRINCIPAL_IDS=<support-agent-principal-id>
# DIRECTIVE_HOSTED_AGENT_PRINCIPAL_IDS=<directive-agent-principal-id>
# LLM runner: "mock" (default when no Azure endpoint) or "real"
LLM_MODE=mock

# ---- Real Azure path ----
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-large

# Foundry project and selectable remote agents
# FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
# FOUNDRY_PROMPT_AGENT_NAME=customer-support-prompt
# FOUNDRY_HOSTED_AGENT_NAME=customer-support-maf-hosted
# Normally omit this override; if set, it must exactly match the project/name route.
# FOUNDRY_HOSTED_AGENT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>/agents/<agent>/endpoint/protocols/openai
# FOUNDRY_PROMPT_ENABLED=false
# FOUNDRY_HOSTED_ENABLED=false
# AGENT_RELEASE_ID=agent-id-auth-20260720-r2
# Responses timeout shared by each Hosted runtime in this phase.
# AGENT_REQUEST_TIMEOUT_SECONDS=120

# Separate directive Hosted Agent (disabled and hidden by default)
# DIRECTIVE_FOUNDRY_AGENT_NAME=directive-rag-maf-hosted
# Normally omit this override; if set, it must exactly match the project/name route.
# DIRECTIVE_FOUNDRY_AGENT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>/agents/<agent>/endpoint/protocols/openai
# DIRECTIVE_AGENT_ENABLED=false
# Visibility controls discovery in /agents, not authorization for an enabled agent.
# DIRECTIVE_AGENT_VISIBLE=false
# DIRECTIVE_AGENT_RELEASE_ID=directive-rag-local
# DIRECTIVE_MODEL_DEPLOYMENT=gpt-5.6-sol
# DIRECTIVE_SEARCH_KB=directive-kb-v1
# DIRECTIVE_SEARCH_KNOWLEDGE_SOURCE=directive-chunks-ks-v1
# DIRECTIVE_SEARCH_API_VERSION=2026-04-01
# DIRECTIVE_COSMOS_DATABASE=directives
# DIRECTIVE_CATALOG_CONTAINER=catalog
# DIRECTIVE_MANDATES_CONTAINER=user_mandates
# DIRECTIVE_BLOB_ENDPOINT=https://<account>.blob.core.windows.net
# DIRECTIVE_BLOB_CONTAINER=directive-artifacts
# DIRECTIVE_MAX_CONTENT_TOKENS=750000
# DIRECTIVE_MAX_SECTIONS_PER_CALL=20
# DIRECTIVE_MAX_SEARCH_RESULTS=25
# DIRECTIVE_MAX_RELATED_DEPTH=2
# Reserved for the directive data-tool layer; it does not control Hosted Responses.
# DIRECTIVE_TOOL_TIMEOUT_SECONDS=120
# DIRECTIVE_PROGRESS_HEARTBEAT_SECONDS=10

# Azure identity (set to the user-assigned MI client ID in Container Apps)
# AZURE_CLIENT_ID=

# Cosmos
# COSMOS_ENDPOINT=
# COSMOS_DATABASE=support
# COSMOS_HISTORY_CONTAINER=history
# COSMOS_PROFILES_CONTAINER=profiles
# COSMOS_MEMORY_CONTAINER=memories

# Search and Foundry IQ
# SEARCH_ENDPOINT=
# SEARCH_ORDERS_KNOWLEDGE_SOURCE=orders-ks
# SEARCH_POLICY_KNOWLEDGE_SOURCE=return-policy-ks
# SEARCH_KB=customer-support-kb
# SEARCH_KNOWLEDGE_API_VERSION=2026-05-01-preview

# Azure Monitor (production uses ManagedIdentityCredential)
# APPLICATIONINSIGHTS_CONNECTION_STRING=
# OTEL_SERVICE_NAME=agent-memory-backend

# Session memory: in-memory only for this build (no Redis)
# REDIS_HOST intentionally left unset.

# CORS: comma-separated allowed origins for the frontend dev server
CORS_ALLOW_ORIGINS=http://localhost:5175,http://127.0.0.1:5175
